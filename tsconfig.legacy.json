{
  "//": "Transpilerar legacy-filer från src/legacy/ till public/js/ som klassiska scripts (inte ES modules). Behåller delad global scope mellan filerna — paritet med pre-Vite-läget. Riktig modularisering sker i Fas 4.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "none",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "alwaysStrict": false,
    "allowJs": true,
    "checkJs": false,
    "rootDir": "./src/legacy",
    "outDir": "./public/js",
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true
  },
  "include": ["src/legacy/**/*"],
  "exclude": ["node_modules", "dist"]
}
